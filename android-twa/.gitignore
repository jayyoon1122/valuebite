# NEVER commit the signing key or built artifacts.
# The keystore is the SOLE thing that authenticates ValueBite to Google Play.
# If lost, you cannot publish updates — Google has no way to recover it.
android.keystore
android.keystore.bak

# Build artifacts (large, regenerated by `bubblewrap build`)
app-release-signed.apk
app-release-bundle.aab
app-release-unsigned-aligned.apk

